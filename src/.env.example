# CODOZ Real Data Engine - Environment Configuration
# Copy this file to .env and fill in your API keys

# Kaggle API (Download from Kaggle account settings)
# Option 1: Place kaggle.json in ~/.kaggle/ directory
# Option 2: Set these environment variables:
KAGGLE_USERNAME=
KAGGLE_KEY=

# Hugging Face API (Get from https://huggingface.co/settings/tokens)
HUGGINGFACE_API_KEY=

# Data.gov API (Optional - for government datasets)
# DATA_GOV_API_KEY=

# Output settings
OUTPUT_FOLDER=codoz_set
